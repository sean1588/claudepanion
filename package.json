{
  "name": "claude-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "claude-manager": "./bin/claude-manager"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:global": "npm link",
    "uninstall:global": "npm unlink -g claude-manager"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.19.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
